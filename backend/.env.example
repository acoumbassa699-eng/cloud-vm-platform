# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgres://cloudvm:cloudvm_dev_password@localhost:5432/cloudvm_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_change_in_production
REFRESH_TOKEN_EXPIRES_IN=30d

# OpenStack Integration
OPENSTACK_AUTH_URL=http://openstack-controller:5000/v3
OPENSTACK_USERNAME=admin
OPENSTACK_PASSWORD=admin
OPENSTACK_PROJECT=admin
OPENSTACK_DOMAIN=Default
OPENSTACK_REGION=RegionOne

# Monitoring
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=cloudvm
INFLUXDB_BUCKET=cloudvm_metrics

# Billing
BILLING_CURRENCY=USD
BILLING_HOURLY_RATE_PER_VCPU=0.10
BILLING_HOURLY_RATE_PER_GB_RAM=0.05
BILLING_HOURLY_RATE_PER_GB_STORAGE=0.01

# Logging
LOG_LEVEL=info
